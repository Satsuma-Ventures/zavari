{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/intelligence/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Serif|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Serif, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|children|style|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: type, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Alert> type must be one of 'info' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|success|warning|error|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'success' | 'warning' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|type|disabled|iconLeft|iconRight|children|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, type, disabled, iconLeft, iconRight, children, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|footer|interactive|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, eyebrow, footer, interactive, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoherenceFlag'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|label|detail|size|style|key|ref|className|style|children)$/]",
        "message": "<CoherenceFlag> doesn't accept that prop. Declared props: state, label, detail, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoherenceFlag'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:coherent|drifting|conflict)$/]",
        "message": "<CoherenceFlag> state must be one of 'coherent' | 'drifting' | 'conflict'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoherenceFlag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<CoherenceFlag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|id|type|placeholder|value|defaultValue|disabled|style|onChange|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, id, type, placeholder, value, defaultValue, disabled, style, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:source|kind|confidence|count|style|key|ref|className|style|children)$/]",
        "message": "<SourceTag> doesn't accept that prop. Declared props: source, kind, confidence, count, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceTag'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:connected|first-party)$/]",
        "message": "<SourceTag> kind must be one of 'connected' | 'first-party'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceTag'] > JSXAttribute[name.name='confidence'] > Literal[value!=/^(?:high|medium|low)$/]",
        "message": "<SourceTag> confidence must be one of 'high' | 'medium' | 'low'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCallout'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|label|trend|align|onDark|style|key|ref|className|style|children)$/]",
        "message": "<StatCallout> doesn't accept that prop. Declared props: value, unit, label, trend, align, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCallout'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<StatCallout> align must be one of 'left' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Alert": { "replaces": [] },
      "Badge": { "replaces": [] },
      "Button": { "replaces": [] },
      "Card": { "replaces": [] },
      "CoherenceFlag": { "replaces": [] },
      "Input": { "replaces": [] },
      "SourceTag": { "replaces": [] },
      "StatCallout": { "replaces": [] }
    },
    "fontFamilies": [
      "IBM Plex Mono",
      "IBM Plex Sans",
      "IBM Plex Serif"
    ]
  }
}
